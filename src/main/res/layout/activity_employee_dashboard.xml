<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/nav_dock_container">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <org.osmdroid.views.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <View
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="@drawable/top_shadow_gradient"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Top Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="54dp"
                android:paddingHorizontal="20dp"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:id="@+id/profile_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_profile_pic"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@color/surface_l2"
                        android:src="@drawable/ic_nav_profile"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.ExtraLargeComponent"
                        app:strokeColor="@color/divider"
                        app:strokeWidth="1dp" />

                    <!-- Status Badges Overlay -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_marginEnd="-4dp"
                        android:layout_marginBottom="-4dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivEmailStatus"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@drawable/bg_circle_surface"
                            android:padding="3dp"
                            android:src="@drawable/ic_email"
                            app:tint="@color/error" />

                        <ImageView
                            android:id="@+id/ivDeviceStatus"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="-6dp"
                            android:background="@drawable/bg_circle_surface"
                            android:padding="3dp"
                            android:src="@drawable/ic_smartphone"
                            app:tint="@color/error" />

                        <ImageView
                            android:id="@+id/ivFaceStatus"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_marginStart="-6dp"
                            android:background="@drawable/bg_circle_surface"
                            android:padding="3dp"
                            android:src="@drawable/ic_face"
                            app:tint="@color/error" />
                    </LinearLayout>
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/user_info_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/profile_container"
                    app:layout_constraintEnd_toStartOf="@id/cardAssignedOffice"
                    app:layout_constraintStart_toEndOf="@id/profile_container"
                    app:layout_constraintTop_toTopOf="@id/profile_container">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning,"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/text_disabled"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Office Selector -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAssignedOffice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#800D1621"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/profile_container">

                    <LinearLayout
                        android:id="@+id/layoutAssignedOffice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_location_pin"
                            app:tint="@color/accent_blue" />

                        <TextView
                            android:id="@+id/tvAssignedOffice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="HQ OFFICE"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginStart="2dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/text_disabled" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Map UI Overlay -->
            <LinearLayout
                android:id="@+id/layout_map_chips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="400dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    app:cardBackgroundColor="#CC071A2F"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <TextView
                        android:id="@+id/tv_map_office_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:paddingHorizontal="12dp"
                        android:text="HQ Office • Floor 3"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="8dp" android:layout_height="1dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    app:cardBackgroundColor="#CC0D223D"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/accent_emerald"
                    app:strokeWidth="1dp">
                    <TextView
                        android:id="@+id/tv_map_confidence_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:paddingHorizontal="12dp"
                        android:text="✓ Attendance Secured"
                        android:textColor="@color/accent_emerald"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Floating Controls -->
            <LinearLayout
                android:id="@+id/layout_map_controls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="400dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_recenter"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#990D1621"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:rippleColor="@color/accent_emerald"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@drawable/ic_target"
                        app:tint="@color/text_secondary" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_menu"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="#990D1621"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:rippleColor="@color/accent_emerald"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:src="@drawable/ic_menu"
                        app:tint="@color/text_secondary" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Bottom Sheet -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/attendance_bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:behavior_peekHeight="380dp"
            app:cardBackgroundColor="@color/background"
            app:cardCornerRadius="32dp"
            app:cardElevation="16dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nested_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <View
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center"
                        android:layout_marginBottom="24dp"
                        android:background="@color/surface_l3" />

                    <!-- Status Bar -->
                    <LinearLayout
                        android:id="@+id/layout_status_bar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_stat_card"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="8dp">

                            <View
                                android:id="@+id/statusIndicatorDot"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/dot_active" />

                            <TextView
                                android:id="@+id/tvStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="✓ Attendance Secured"
                                android:textColor="@color/accent_emerald"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvDistanceOffice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Safely inside HQ."
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Hero Greeting -->
                    <TextView
                        android:id="@+id/tvHeroGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Ready to start\nyour day?"
                        android:textColor="@color/white"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <!-- Main Attendance Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/attendance_main_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:cardBackgroundColor="@color/surface_l1"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/divider"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <!-- Timer -->
                            <LinearLayout
                                android:id="@+id/timerContainer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="ACTIVE WORK SESSION"
                                    android:textColor="@color/text_disabled"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvTimer"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="00h 00m"
                                    android:textColor="@color/white"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvEstCheckout"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="EST. CHECKOUT: 05:30 PM"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />
                            </LinearLayout>

                            <!-- Success State -->
                            <LinearLayout
                                android:id="@+id/completedContainer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/ic_check_circle"
                                    app:tint="@color/accent_emerald"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:text="Attendance Logged"
                                    android:textColor="@color/white"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvCompletedSub"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="Good Job! See you tomorrow."
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp"
                                    android:gravity="center" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="16dp"
                                    android:orientation="horizontal"
                                    android:gravity="center">
                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                                        <TextView android:id="@+id/tv_worked_today" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="08h 42m" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WORKED" android:textColor="@color/text_disabled" android:textSize="9sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                    <View android:layout_width="1dp" android:layout_height="20dp" android:background="@color/divider"/>
                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                                        <TextView android:id="@+id/tv_checked_in_at" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="08:46 AM" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="IN" android:textColor="@color/text_disabled" android:textSize="9sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                    <View android:layout_width="1dp" android:layout_height="20dp" android:background="@color/divider"/>
                                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                                        <TextView android:id="@+id/tv_checked_out_at" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="05:28 PM" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold"/>
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OUT" android:textColor="@color/text_disabled" android:textSize="9sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCheckIn"
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:layout_marginTop="8dp"
                                android:backgroundTint="@color/accent_emerald"
                                android:text="CHECK IN"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                app:cornerRadius="16dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCheckOut"
                                style="@style/Widget.Material3.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:layout_marginTop="20dp"
                                android:backgroundTint="@color/surface_l2"
                                android:text="CHECK OUT"
                                android:textColor="@color/white"
                                android:textStyle="bold"
                                app:cornerRadius="16dp"
                                app:strokeColor="@color/divider"
                                app:strokeWidth="1dp"
                                app:icon="@drawable/ic_logout"
                                app:iconGravity="textStart"
                                app:iconPadding="12dp"
                                app:iconTint="@color/text_secondary"
                                android:visibility="gone"/>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Insights Cards -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardBackgroundColor="@color/surface_l1"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/divider"
                            app:strokeWidth="1dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:gravity="center" android:orientation="vertical">
                                <ImageView
                                    android:id="@+id/iv_fire_streak"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_fire"
                                    app:tint="@color/accent_gold" />
                                <TextView android:id="@+id/tvStreakCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="0 Days" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STREAK" android:textColor="@color/text_disabled" android:textSize="9sp" android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardBackgroundColor="@color/surface_l1"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/divider"
                            app:strokeWidth="1dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:gravity="center" android:orientation="vertical">
                                <ImageView
                                    android:id="@+id/iv_calendar_stat"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_calendar"
                                    app:tint="@color/accent_blue" />
                                <TextView android:id="@+id/tvAttendancePercent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="0%" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="THIS MONTH" android:textColor="@color/text_disabled" android:textSize="9sp" android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Weekly Snapshot -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekly Progress" android:textColor="@color/white" android:textSize="14sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tv_weekly_avg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="--" android:textColor="@color/accent_emerald" android:textSize="12sp" android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Weekly Work Hours Chart -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/weeklyLineChart"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="12dp" />

                    <!-- Weekly Stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/tv_weekly_present" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PRESENT" android:textColor="@color/text_disabled" android:textSize="8sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/tv_weekly_late" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/accent_gold" android:textSize="16sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LATE" android:textColor="@color/text_disabled" android:textSize="8sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:id="@+id/tv_weekly_absent" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textColor="@color/error" android:textSize="16sp" android:textStyle="bold"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ABSENT" android:textColor="@color/text_disabled" android:textSize="8sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/weekly_progress_indicator"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            app:indicatorColor="@color/accent_emerald"
                            app:trackColor="@color/surface_l1"
                            app:trackThickness="3dp"
                            android:progress="0"/>
                    </LinearLayout>

                    <!-- Today's Activity Section (Moved to Bottom) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="Today's Activity"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="@color/surface_l1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/divider"
                        app:strokeWidth="1dp">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvTimeline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp"
                            android:nestedScrollingEnabled="false"
                            tools:listitem="@layout/item_timeline" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </com.google.android.material.card.MaterialCardView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Premium Floating Control Dock -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/nav_dock_container"
        style="@style/Widget.GeoAttend.FloatingDock"
        android:layout_width="320dp"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            style="@style/Widget.GeoAttend.BottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:menu="@menu/bottom_nav_menu" />

    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>
