<resources>
    <!-- Base application theme. -->
    <style name="Theme.GeoAttend" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/accent_emerald</item>
        <item name="colorTertiary">@color/accent_blue</item>
        
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_light</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.GeoAttend.HeadlineLarge</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.GeoAttend.TitleLarge</item>
    </style>

    <style name="TextAppearance.GeoAttend.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.GeoAttend.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ShapeAppearance.Material3.ExtraLargeComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">28dp</item>
    </style>

    <!-- PREMIUM FLOATING DOCK STYLES -->
    <style name="Widget.GeoAttend.FloatingDock" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">#E60D1621</item>
        <item name="cardCornerRadius">32dp</item>
        <item name="cardElevation">12dp</item>
        <item name="strokeColor">#26FFFFFF</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.GeoAttend.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@android:color/transparent</item>
        <item name="itemIconSize">22dp</item>
        <item name="itemIconTint">@drawable/nav_item_state_list</item>
        <item name="itemTextColor">@drawable/nav_item_state_list</item>
        <item name="itemRippleColor">@null</item>
        <item name="itemActiveIndicatorStyle">@null</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.GeoAttend.NavLabel</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.GeoAttend.NavLabel</item>
        <item name="itemPaddingTop">18dp</item>
        <item name="itemPaddingBottom">10dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <style name="TextAppearance.GeoAttend.NavLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>