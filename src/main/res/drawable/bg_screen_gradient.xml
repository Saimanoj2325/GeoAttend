<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#071A2F"
                android:startColor="#0D223D"
                android:type="linear" />
        </shape>
    </item>
    <!-- Subtle top glow -->
    <item android:top="-200dp" android:left="-100dp" android:right="-100dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:startColor="#1A3B82F6"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
